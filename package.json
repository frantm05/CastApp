    "expo-keep-awake": "~15.0.8",
    "expo-network": "~8.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-tcp-socket": "^6.4.1",
    "react-native-udp": "^4.1.7",
    "react-native-webview": "13.15.0",
    "zustand": "^5.0.12"
